{
  "name": "biltest-listing-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Build in Lombok — home-PC Listing Worker (docs/adr/0007). Headless-browser ingestion + nightly re-check; outbound-only to HostPapa.",
  "type": "module",
  "engines": { "node": ">=18" },
  "scripts": {
    "start": "node listing-worker.js",
    "recheck": "node listing-worker.js --recheck-only",
    "discover": "node listing-worker.js --discover-only",
    "ping": "node listing-worker.js --ping",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "playwright": "^1.45.0"
  }
}
