# Build in Lombok — Listing Worker config. Copy to .env and fill in.
# .env is gitignored; never commit real values.

# Full path to the ingest endpoint (NOT just the domain).
API_BASE=https://biltest.roving-i.com.au/api/listing_ingest.php

# Must equal WORKER_API_KEY in /home/rovin629/config/biltest_config.php (exact, no quotes/spaces).
WORKER_KEY=replace-with-the-shared-secret

# Re-check / discovery batch sizes (server caps re-check at 500).
RECHECK_LIMIT=80
DISCOVERY_LIMIT=40

# Politeness: random delay between page loads (ms).
DELAY_MIN_MS=30000
DELAY_MAX_MS=60000

# 1 = show the browser (debugging); 0 = headless.
HEADFUL=0
