# Build in Lombok — Listing Worker config
# Copy to ".env" and fill in. NEVER commit the real .env.

# The ingest API on HostPapa (note: HTTPS, public host).
API_BASE=https://biltest.roving-i.com.au/api/listing_ingest.php

# Must equal WORKER_API_KEY in /home/rovin629/config/biltest_config.php
WORKER_KEY=replace-with-the-shared-secret

# Re-check batch size handed out per run (matches RECHECK_BATCH_DEFAULT server-side)
RECHECK_LIMIT=80

# Max NEW detail pages to fetch from discovery per run (keeps the footprint small)
DISCOVERY_LIMIT=40

# Politeness: random delay between page loads, milliseconds (min..max)
DELAY_MIN_MS=30000
DELAY_MAX_MS=60000

# Set to 1 to watch the browser (debugging); 0 = headless for the scheduled run
HEADFUL=0
