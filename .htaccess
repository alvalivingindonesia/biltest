# ==========================================================================
# Build in Lombok — root .htaccess  (security hardening)
# Closes/​mitigates SEC-009, SEC-007, SEC-033, SEC-031 (defense-in-depth),
# SEC-034 (CSP backstop), SEC-036.
# api/, admin/, uploads/ keep their own .htaccess in addition to this.
# ==========================================================================

# No directory listings anywhere.
Options -Indexes

# --- Force HTTPS (SEC-009 / SEC-011: protects the session cookie) ----------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# --- Neutralise anything the old "cp -R ." deploy may have published -------
# (.git history, raw SQL migrations, internal docs, worker/agent source).
# These dirs may still exist on disk from earlier deploys; this makes them
# unreachable over HTTP. The .cpanel.yml allow-list stops re-publishing them.
RedirectMatch 404 ^/(\.git|\.github|migrations|docs|worker|agent|database)(/|$)

# --- Block sensitive file types by extension (site-wide) -------------------
<FilesMatch "\.(md|sql|ya?ml|sh|bat|log|env|sample|lock|ini|toml|map|dist|bak|gitignore|gitattributes|modelfile)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# --- Block dotfiles (.env, .git*, editor/CI dotfiles) ----------------------
<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>

# --- Security response headers (SEC-009; CSP also backstops SEC-002..005) ---
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

  # NOTE: 'unsafe-inline' on script-src/style-src is currently required because
  # the SPA still uses inline onclick handlers and inline <script> blocks.
  # The primary XSS defence is output escaping (SEC-002..005,015..017,028,029);
  # CSP here restricts script ORIGINS, kills inline objects/base-uri/framing,
  # and is tightened to nonces once inline handlers are removed.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://accounts.google.com https://apis.google.com https://connect.facebook.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://accounts.google.com https://oauth2.googleapis.com https://www.googleapis.com https://graph.facebook.com; frame-src 'self' https://accounts.google.com https://www.facebook.com https://web.facebook.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests"
</IfModule>
